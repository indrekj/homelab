# Copy to .env and fill in. Never commit .env.

# Traefik ACME (Cloudflare DNS-01)
LETSENCRYPT_EMAIL=you@example.com
CLOUDFLARE_API_TOKEN=

# PostgreSQL superuser password.
POSTGRES_PASSWORD=""

# Plex claim token from https://www.plex.tv/claim — only needed on first
# run of a fresh install; leave blank once Plex has been claimed.
PLEX_CLAIM=

# Recyclarr syncs TRaSH-Guides settings into Radarr/Sonarr. API keys from each
# app's Settings -> General -> Security.
RADARR_API_KEY=
SONARR_API_KEY=
